# Public Supabase credentials (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Private Supabase service role key (SERVER SIDE ONLY - NEVER EXPOSE TO CLIENT)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Secret key used to sign virtual event passes (HMAC-SHA256)
# Generate a secure random string (e.g. openssl rand -hex 32)
PASS_SECRET=your-secure-pass-signing-secret

# Email Service Configuration (Resend) - Optional for Phase 0, required by Phase 4
RESEND_API_KEY=your-resend-api-key
